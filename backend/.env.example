APP_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-real-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Local default: sqlite
DB_ENGINE=sqlite
DB_NAME=/root/.openclaw/workspace/projects/finmodpro-backend/db.sqlite3
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_CONN_MAX_AGE=60

# Redis
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT
JWT_SECRET_KEY=replace-with-a-real-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=7200

# RBAC
# No extra environment variables. Roles and permissions are seeded by:
# .venv/bin/python manage.py seed_rbac
