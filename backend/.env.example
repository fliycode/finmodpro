# FinModPro backend environment example
# Copy this file to `.env` and adjust only what you need.

# ------------------------------------------------------------------------------
# Django / DRF
# ------------------------------------------------------------------------------
APP_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-local-dev-secret
DJANGO_ALLOWED_HOSTS=47.85.103.76,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://47.85.103.76:5173,http://127.0.0.1:5173,http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://47.85.103.76:5173,http://127.0.0.1:5173,http://localhost:5173

# Optional. If omitted, settings.py falls back to backend/media.
MEDIA_URL=/media/
MEDIA_ROOT=media

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Local dev can stay on sqlite.
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# Enable these when DB_ENGINE=mysql.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_CONN_MAX_AGE=60

# ------------------------------------------------------------------------------
# Redis / Cache
# ------------------------------------------------------------------------------
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# Celery
# ------------------------------------------------------------------------------
# Local dev can use in-memory transport; production should use Redis or another broker.
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_TASK_STORE_EAGER_RESULT=false

# ------------------------------------------------------------------------------
# Chat maintenance
# ------------------------------------------------------------------------------
# Optional runtime knobs for chat context assembly and rolling maintenance jobs.
# Values must be valid integers or Django settings loading will fail at startup.
CHAT_CONTEXT_RECENT_MESSAGES=8
CHAT_MEMORY_RESULT_LIMIT=5
CHAT_SUMMARY_TRIGGER_MESSAGES=6

# ------------------------------------------------------------------------------
# LiteLLM / Langfuse
# ------------------------------------------------------------------------------
LITELLM_INTERNAL_URL=http://litellm:4000
LITELLM_MASTER_KEY=replace-with-a-local-litellm-key
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ------------------------------------------------------------------------------
# Knowledge base / Milvus
# ------------------------------------------------------------------------------
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=
MILVUS_COLLECTION_NAME=knowledgebase_document_chunks
KB_CHUNK_SIZE=400
KB_CHUNK_OVERLAP=50
KB_EMBEDDING_DIMENSION=64

# ------------------------------------------------------------------------------
# Unstructured parser service
# ------------------------------------------------------------------------------
UNSTRUCTURED_API_URL=http://unstructured-api:8000
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_TIMEOUT_SECONDS=30
UNSTRUCTURED_PDF_STRATEGY=auto
UNSTRUCTURED_DOCX_STRATEGY=auto
UNSTRUCTURED_PDF_FALLBACK_ENABLED=true

# ------------------------------------------------------------------------------
# Fine-tune control plane
# ------------------------------------------------------------------------------
FINE_TUNE_EXPORT_ROOT=exports/fine-tune-runs
FINE_TUNE_EXPORT_BASE_URL=
FINE_TUNE_CALLBACK_SECRET=replace-with-a-local-fine-tune-callback-secret
LITELLM_GENERATED_CONFIG_ROOT=../deploy/litellm/generated

# ------------------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------------------
# If omitted, JWT_SECRET_KEY falls back to DJANGO_SECRET_KEY.
JWT_SECRET_KEY=replace-with-a-local-dev-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=7200

# ------------------------------------------------------------------------------
# Notes
# ------------------------------------------------------------------------------
# Ollama endpoint / model name are not read from environment variables today.
# They are managed through the ModelConfig records in the database / ops APIs.
# DeepSeek is also managed through the ModelConfig records in the database / ops APIs.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
